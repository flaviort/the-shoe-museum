{
  "name": "the-shoe-museum-shopify",
  "version": "1.0.0",
  "description": "The Shoe Museum - Shopify theme",
  "main": "gulpfile.mjs",
  "scripts": {
    "dev": "concurrently \"shopify theme dev --store the-shoe-museum.myshopify.com\" \"gulp watch\"",
    "build": "gulp build",
    "push": "shopify theme push --theme \"The Shoe Museum\" --store=\"the-shoe-museum.myshopify.com\"",
    "sass": "gulp watch",
    "js": "gulp compileJS"
  },
  "type": "module",
  "devDependencies": {
    "concurrently": "^9.2.0",
    "gulp": "^5.0.0",
    "gulp-rename": "^2.0.0"
  },
  "dependencies": {
    "gulp-autoprefixer": "^9.0.0",
    "gulp-clean-css": "^4.3.0",
    "gulp-sass": "^5.1.0",
    "gulp-sourcemaps": "^3.0.0",
    "sass": "^1.77.7",
    "gulp-uglify": "^3.0.2"
  }
}
