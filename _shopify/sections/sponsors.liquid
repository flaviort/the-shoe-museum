{%- assign sponsor_entries = shop.metaobjects.sponsors.values -%}
{%- if sponsor_entries.size > 0 -%}

<section class="sponsors-section py-medium py-md-small">

  <div class="container">
    <div class="top">

      <h2 class="text-60 uppercase bold">
        {{ section.settings.title }}
      </h2>

      {%- if section.settings.subtitle != blank -%}
        <p class="text-20">
          {{ section.settings.subtitle }}
        </p>
      {%- endif -%}

    </div>
  </div>

  <div class="sponsors-marquee mt-smaller">
    {%- for entry in sponsor_entries -%}
      {%- assign logo  = entry.logo.value -%}
      {%- assign label = entry.label.value -%}
      {%- assign url   = entry.url.value -%}

      {%- if logo != blank -%}

        {%- if url != blank -%}
          <a
            href="{{ url }}"
            class="sponsor-block"
            target="_blank"
            rel="noopener noreferrer"
          >
        {%- else -%}
          <div class="sponsor-block">
        {%- endif -%}

          <img
            src="{{ logo | image_url: width: 300 }}"
            alt="{{ label | default: '' }}"
            width="100"
            height="100"
            loading="lazy"
          />

        {%- if url != blank -%}
          </a>
        {%- else -%}
          </div>
        {%- endif -%}

      {%- endif -%}
    {%- endfor -%}
  </div>

</section>

{%- endif -%}

{% schema %}
{
  "name": "Sponsors",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Sponsors"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "We work with the best in the business."
    }
  ],
  "presets": [
    {
      "name": "Sponsors"
    }
  ]
}
{% endschema %}
