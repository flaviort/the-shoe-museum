{%- comment -%}
  Snippet: product-block.liquid
  Expects: product (product object)

  Badge tags: prefix product tags with "badge:" in Shopify admin
  e.g. "badge:Just arrived", "badge:Few units left"
{%- endcomment -%}

{%- assign has_badges = false -%}
{%- for tag in product.tags -%}
  {%- if tag contains 'badge:' -%}
    {%- assign has_badges = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

<a href="{{ product.url }}" class="product-block">

  {%- if has_badges -%}
    <span class="product-block__tags">
      {%- for tag in product.tags -%}
        {%- if tag contains 'badge:' -%}
          <span class="tag">{{ tag | remove: 'badge:' }}</span>
        {%- endif -%}
      {%- endfor -%}
    </span>
  {%- endif -%}

  <span class="product-block__image">
    {%- if product.featured_image != blank -%}
      <img
        src="{{ product.featured_image | image_url: width: 800 }}"
        alt="{{ product.featured_image.alt | default: product.title }}"
        width="800"
        height="800"
        loading="lazy"
      />
    {%- endif -%}
  </span>

  <span class="product-block__infos">

    <p class="product-block__name">{{ product.title }}</p>

    <p class="product-block__price">
      {%- if product.variants.size > 1 -%}
        <small>from</small>
      {%- endif -%}
      {{ product.price_min | money }}
      {%- if product.compare_at_price_max > product.price_min -%}
        <s>{{ product.compare_at_price_max | money }}</s>
      {%- endif -%}
    </p>

  </span>

</a>
